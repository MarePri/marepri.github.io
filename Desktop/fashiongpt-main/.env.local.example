# ─── OpenAI ─────────────────────────────────────────────────────────────────────
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Weather (OpenWeatherMap) ──────────────────────────────────────────────────
# Get your free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ─── Supabase ───────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── FashionGPT Vite Overrides ─────────────────────────────────────────────────
# Vite uses VITE_ prefix. Set these in .env.local for local dev.

# Backend proxy URL — keeps the Anthropic API key server-side.
# Start the proxy: cd server && npm install && npm run dev
# The proxy reads ANTHROPIC_API_KEY from server/.env
VITE_API_PROXY_URL=http://localhost:3001

# Anthropic API Key — optional (used directly only if proxy is not configured).
# Without a key or proxy, the app runs in offline/mock mode.
VITE_ANTHROPIC_API_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

