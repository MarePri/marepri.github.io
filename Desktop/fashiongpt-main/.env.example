# ═══════════════════════════════════════════════════════════════════════════
# FashionGPT — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# FashionGPT runs in two tiers:
#   1. Frontend (Vite React SPA) — uses VITE_* vars, built into the bundle
#   2. Backend proxy (server/index.js) — keeps the API key server-side
#
# Offline/mock mode: If no API keys are configured, the app falls back
# to deterministic rule-based outfit generation. No external API calls.
# This is the default and works perfectly for evaluation.
#
# Copy this file to both:
#   .env.local         — frontend dev (Vite reads this automatically)
#   server/.env        — backend proxy (loaded via dotenv in server/index.js)

# ── Backend Proxy (server/.env) ─────────────────────────────────────────
# The Express proxy keeps the Anthropic key server-side, never in the bundle.
ANTHROPIC_API_KEY=sk-ant-your-key-here
PORT=3001

# ── Frontend (Vite — .env.local) ────────────────────────────────────────
# Proxy URL the frontend calls for AI generation.
# Defaults to http://localhost:3001 when running the local Express server.
VITE_API_PROXY_URL=http://localhost:3001

# Optional: Direct Anthropic key (bypasses proxy, embeds in bundle — use only
# for local prototyping where you don't want to run the Express server).
# VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Weather service (free tier https://openweathermap.org/api).
# Without this, the app falls back to mock weather data for Madrid.
VITE_OPENWEATHER_API_KEY=your_openweather_key

# Optional: Supabase persistence (https://supabase.com).
# Without these, saved outfits are stored in-memory/localStorage only.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
